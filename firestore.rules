rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.enabled == true;
    }

    // Énigmes : lecture publique, écriture réservée aux admins Firebase.
    match /enigmes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TODO sécurité: `guesses` et `users` sont encore ouverts (MVP).
    // Pour une sécurité complète, il faut lier les joueurs à Firebase Auth
    // et appliquer des règles basées sur request.auth.uid.
    match /guesses/{id} {
      allow read, write: if true;
    }
    match /users/{id} {
      allow read, write: if true;
    }

    // Référentiel admin Storage : créé / modifié uniquement depuis la console Firebase
    // (le client ne doit pas pouvoir s’auto-promouvoir).
    match /admins/{uid} {
      allow read, write: if false;
    }
  }
}
