# Mot de passe de la page /admin (sinon valeur de secours : dev-admin)
VITE_ADMIN_PASSWORD=

# true = Firestore même en dev | false = localStorage même en build | absent = Firestore si PROD uniquement
# VITE_USE_FIREBASE=

# Compte Firebase Auth « admin » (même e-mail que dans Authentication) — pour l’écriture Storage en prod
# Après première connexion, créer dans Firestore le document admins/{UID} avec enabled: true
# VITE_FIREBASE_ADMIN_EMAIL=
# VITE_FIREBASE_ADMIN_PASSWORD=

# Firebase — copier depuis la console (Paramètres du projet > Vos applications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
